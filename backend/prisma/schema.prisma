generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =================== ENUMS ===================

enum UserRole {
  ADMIN
  MANAGER
  TECHNICIAN
  CLIENT
}

enum UserType {
  INTERNAL
  CLIENT
}

enum TicketStatus {
  AWAITING_TRIAGE
  OPEN
  IN_PROGRESS
  WAITING_CLIENT
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ProjectStatus {
  PLANNING
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum TaskStatus {
  NOT_STARTED
  WORKING_ON_IT
  STUCK
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum ContractStatus {
  DRAFT
  ACTIVE
  EXPIRED
  CANCELLED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum ExpenseCategory {
  SOFTWARE
  HARDWARE
  TRAVEL
  SERVICES
  UTILITIES
  OTHER
}

enum AssetStatus {
  IN_STOCK
  DEPLOYED
  LOST
  STOLEN
  DECOMMISSIONED
  SHIPPING
}

enum ShipmentStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum ChangeStatus {
  DRAFT
  SUBMITTED
  INTERNAL_REVIEW
  CUSTOMER_REVIEW
  APPROVED
  REJECTED
  FAILED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ChangeRisk {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

// =================== MODELS ===================

model User {
  id                String   @id @default(uuid())
  email             String   @unique
  password          String?
  firstName         String
  lastName          String
  role              UserRole @default(TECHNICIAN)
  userType          UserType @default(INTERNAL)
  twoFactorEnabled  Boolean  @default(false)
  twoFactorSecret   String?
  avatar            String?
  phone             String?
  jobTitle          String?
  isActive          Boolean  @default(true)
  canApproveChanges Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  companyId         String?
  company           Company? @relation(fields: [companyId], references: [id])

  assignedTickets    Ticket[]        @relation("AssignedTechnician")
  createdTickets     Ticket[]        @relation("TicketCreator")
  ticketComments     TicketComment[]
  ticketHistory      TicketHistory[]
  assignedTasks      Task[]          @relation("AssignedUser")
  createdTasks       Task[]          @relation("TaskCreator")
  timeEntries        TimeEntry[]
  projects           ProjectMember[]
  todos              Todo[]
  refreshTokens      RefreshToken[]
  macros             Macro[]
  notifications      Notification[]
  internalApprovalChanges Change[] @relation("InternalApprover")
  createdChanges          Change[] @relation("ChangeCreator")
  shipmentRequests        ShipmentRequest[]
  taskComments       TaskComment[]
  activeTimers       ActiveTimer[]
  taskAssignees  TaskAssignee[]
  createdTemplates   ProjectTemplate[] @relation("TemplateCreator")
  projectComments    ProjectComment[]
  managedCompanies   Company[] @relation("AccountManager")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@map("refresh_tokens")
}

model TicketCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String   @default("#6366f1")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  tickets   Ticket[]

  @@map("ticket_categories")
}

model Macro {
  id          String   @id @default(uuid())
  name        String
  content     String
  isGlobal    Boolean  @default(true)
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("macros")
}

model SlaPolicy {
  id             String         @id @default(uuid())
  priority       TicketPriority @unique
  responseTime   Int
  resolutionTime Int
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@map("sla_policies")
}

model Company {
  id          String   @id @default(uuid())
  name        String
  domain      String?
  industry    String?
  phone       String?
  email       String?
  address     String?
  city        String?
  state       String?
  zip         String?
  country     String?
  website     String?
  notes       String?
  isActive    Boolean  @default(true)
  isInternal  Boolean  @default(false)
  accountManagerId String?
  accountManager   User?    @relation("AccountManager", fields: [accountManagerId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contacts    Contact[]
  tickets     Ticket[]
  projects    Project[]
  leads       Lead[]
  contracts   Contract[]
  invoices    Invoice[]
  assets      Asset[]
  changes     Change[]
  users       User[]

  @@map("companies")
}

model Contact {
  id          String   @id @default(uuid())
  firstName   String
  lastName    String
  email       String?
  phone       String?
  title       String?
  isPrimary   Boolean  @default(false)
  notes       String?
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tickets     Ticket[]
  leads       Lead[]

  @@map("contacts")
}

model Lead {
  id          String     @id @default(uuid())
  title       String
  value       Float?
  status      LeadStatus @default(NEW)
  source      String?
  notes       String?
  companyId   String?
  company     Company?   @relation(fields: [companyId], references: [id])
  contactId   String?
  contact     Contact?   @relation(fields: [contactId], references: [id])
  expectedClose DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("leads")
}

model Ticket {
  id              String          @id @default(uuid())
  number          Int             @unique @default(autoincrement())
  title           String
  description     String?
  status          TicketStatus    @default(AWAITING_TRIAGE)
  priority        TicketPriority  @default(MEDIUM)
  categoryId      String?
  category        TicketCategory? @relation(fields: [categoryId], references: [id])
  tags            String[]
  dueDate         DateTime?
  resolvedAt      DateTime?
  slaResolutionDue DateTime?
  slaResponseDue   DateTime?
  companyId       String?
  company         Company?        @relation(fields: [companyId], references: [id])
  contactId       String?
  contact         Contact?        @relation(fields: [contactId], references: [id])
  assignedToId    String?
  assignedTo      User?           @relation("AssignedTechnician", fields: [assignedToId], references: [id])
  createdById     String
  createdBy       User            @relation("TicketCreator", fields: [createdById], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  comments        TicketComment[]
  history         TicketHistory[]
  timeEntries     TimeEntry[]
  attachments     Attachment[]

  @@map("tickets")
}

model TicketComment {
  id         String   @id @default(uuid())
  content    String
  isInternal Boolean  @default(false)
  ticketId   String
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("ticket_comments")
}

model TicketHistory {
  id        String   @id @default(uuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  field     String
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  @@map("ticket_history")
}

model Project {
  id          String        @id @default(uuid())
  name        String
  description String?
  status      ProjectStatus @default(PLANNING)
  startDate   DateTime?
  endDate     DateTime?
  budget      Float?
  companyId   String?
  company     Company?      @relation(fields: [companyId], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  members     ProjectMember[]
  tasks       Task[]
  timeEntries TimeEntry[]
  sections    Section[]
  comments    ProjectComment[]

  @@map("projects")
}

model ProjectMember {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  role      String   @default("MEMBER")
  createdAt DateTime @default(now())

  @@unique([projectId, userId])
  @@map("project_members")
}

model Section {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  color     String   @default("#6366f1")
  order     Int      @default(0)
  collapsed Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks     Task[]

  @@map("sections")
}

model Task {
  id             String       @id @default(uuid())
  number         Int          @unique @default(autoincrement())
  title          String
  description    String?
  status         TaskStatus   @default(NOT_STARTED)
  priority       TaskPriority @default(MEDIUM)
  tags           String[]
  startDate      DateTime?
  dueDate        DateTime?
  completedAt    DateTime?
  estimatedHours Float?
  projectId      String?
  project        Project?     @relation(fields: [projectId], references: [id])
  sectionId      String?
  section        Section?     @relation(fields: [sectionId], references: [id])
  order          Int          @default(0)
  assignedToId   String?
  assignedTo     User?        @relation("AssignedUser", fields: [assignedToId], references: [id])
  createdById    String
  createdBy      User         @relation("TaskCreator", fields: [createdById], references: [id])
  parentTaskId   String?
  parentTask     Task?        @relation("SubTasks", fields: [parentTaskId], references: [id])
  subTasks       Task[]       @relation("SubTasks")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  timeEntries    TimeEntry[]
  attachments    Attachment[]
  comments       TaskComment[]
  activeTimers   ActiveTimer[]
  assignees      TaskAssignee[]

  @@map("tasks")
}

model TaskAssignee {
  taskId String
  userId String
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id])

  @@id([taskId, userId])
  @@map("task_assignees")
}

model TaskComment {
  id        String   @id @default(uuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("task_comments")
}

model ActiveTimer {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
  startedAt DateTime @default(now())

  @@unique([taskId, userId])
  @@map("active_timers")
}

model TimeEntry {
  id          String   @id @default(uuid())
  description String?
  hours       Float
  date        DateTime @default(now())
  billable    Boolean  @default(true)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  ticketId    String?
  ticket      Ticket?  @relation(fields: [ticketId], references: [id])
  taskId      String?
  task        Task?    @relation(fields: [taskId], references: [id])
  projectId   String?
  project     Project? @relation(fields: [projectId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("time_entries")
}

model Contract {
  id           String         @id @default(uuid())
  name         String
  description  String?
  status       ContractStatus @default(DRAFT)
  startDate    DateTime
  endDate      DateTime
  value        Float
  billingCycle String?
  companyId    String
  company      Company        @relation(fields: [companyId], references: [id])
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  invoices     Invoice[]

  @@map("contracts")
}

model Invoice {
  id         String        @id @default(uuid())
  number     String        @unique
  status     InvoiceStatus @default(DRAFT)
  issueDate  DateTime      @default(now())
  dueDate    DateTime
  subtotal   Float
  tax        Float         @default(0)
  total      Float
  notes      String?
  companyId  String
  company    Company       @relation(fields: [companyId], references: [id])
  contractId String?
  contract   Contract?     @relation(fields: [contractId], references: [id])
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  items      InvoiceItem[]

  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(uuid())
  description String
  quantity    Float
  unitPrice   Float
  total       Float
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@map("invoice_items")
}

model Expense {
  id          String          @id @default(uuid())
  title       String
  amount      Float
  category    ExpenseCategory @default(OTHER)
  date        DateTime        @default(now())
  description String?
  receipt     String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@map("expenses")
}

model Todo {
  id          String    @id @default(uuid())
  title       String
  description String?
  completed   Boolean   @default(false)
  dueDate     DateTime?
  priority    String    @default("MEDIUM")
  tags        String[]
  userId      String
  user        User      @relation(fields: [userId], references: [id])
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("todos")
}

model Attachment {
  id        String   @id @default(uuid())
  name      String
  url       String
  size      Int
  mimeType  String
  ticketId  String?
  ticket    Ticket?  @relation(fields: [ticketId], references: [id])
  taskId    String?
  task      Task?    @relation(fields: [taskId], references: [id])
  createdAt DateTime @default(now())

  @@map("attachments")
}

model Announcement {
  id        String   @id @default(uuid())
  title     String
  content   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("announcements")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  ticketId  String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("notifications")
}

model Manufacturer {
  id        String   @id @default(uuid())
  name      String   @unique
  website   String?
  phone     String?
  email     String?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets    Asset[]

  @@map("manufacturers")
}

model Asset {
  id             String        @id @default(uuid())
  number         Int           @unique @default(autoincrement())
  name           String
  modelNumber    String?
  serialNumber   String?
  status         AssetStatus   @default(IN_STOCK)
  purchaseDate   DateTime?
  purchasePrice  Float?
  warrantyExpiry DateTime?
  notes          String?
  manufacturerId String?
  manufacturer   Manufacturer? @relation(fields: [manufacturerId], references: [id])
  companyId      String?
  company        Company?      @relation(fields: [companyId], references: [id])
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  shipmentRequests ShipmentRequest[]

  @@map("assets")
}

model ShipmentRequest {
  id            String         @id @default(uuid())
  assetId       String
  asset         Asset          @relation(fields: [assetId], references: [id])
  recipientName String
  company       String?
  addressLine1  String
  addressLine2  String?
  city          String
  state         String?
  zip           String?
  country       String         @default("UK")
  purpose       String
  status        ShipmentStatus @default(PENDING)
  notes         String?
  requestedById String
  requestedBy   User           @relation(fields: [requestedById], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@map("shipment_requests")
}

model Change {
  id                 String       @id @default(uuid())
  number             Int          @unique @default(autoincrement())
  title              String
  status             ChangeStatus @default(DRAFT)
  risk               ChangeRisk   @default(MEDIUM)

  scheduledStart     DateTime?
  durationMinutes    Int?

  companyId          String?
  companyRef         Company?     @relation(fields: [companyId], references: [id])

  scope              String?
  reason             String?
  risks              String?
  implementationPlan String?
  validationSteps    String?
  rollbackSteps      String?

  internalApproverId    String?
  internalApprover      User?    @relation("InternalApprover", fields: [internalApproverId], references: [id])
  internalApprovedAt    DateTime?
  internalRejectedAt    DateTime?
  internalNotes         String?

  customerApproverName  String?
  customerApproverEmail String?
  customerApprovedAt    DateTime?
  customerRejectedAt    DateTime?
  customerNotes         String?

  createdById  String
  createdBy    User     @relation("ChangeCreator", fields: [createdById], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("changes")
}

model ProjectTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdById String
  createdBy   User     @relation("TemplateCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sections    TemplateSection[]

  @@map("project_templates")
}

model TemplateSection {
  id         String          @id @default(uuid())
  templateId String
  template   ProjectTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  name       String
  color      String          @default("#6366f1")
  order      Int             @default(0)

  tasks      TemplateTask[]

  @@map("template_sections")
}

model TemplateTask {
  id             String        @id @default(uuid())
  sectionId      String
  section        TemplateSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  estimatedHours Float?
  order          Int           @default(0)
  parentTaskId   String?
  parentTask     TemplateTask? @relation("TemplateSubTasks", fields: [parentTaskId], references: [id])
  subTasks       TemplateTask[] @relation("TemplateSubTasks")

  @@map("template_tasks")
}

model ProjectComment {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("project_comments")
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}
